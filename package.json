{
  "name": "parthbuildersf-monorepo",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "node scripts/dev-all.mjs",
    "dev:backend": "npm --prefix Backend run dev",
    "dev:admin": "npm --prefix Frontend run dev",
    "dev:customer": "npm --prefix CustomerFrontend run dev",
    "build": "npm --prefix Backend run build --if-present && npm --prefix Frontend run build && npm --prefix CustomerFrontend run build",
    "build:admin": "npm --prefix Frontend run build",
    "build:customer": "npm --prefix CustomerFrontend run build"
  }
}
