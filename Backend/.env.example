PORT=3000
PORT_FALLBACK_ATTEMPTS=20

MONGO_DB_URL=mongodb://localhost:27017/your-db
SESSION_SECRET=change-this-secret

# Comma-separated list of allowed origins for production.
# In local dev, localhost origins are allowed when ALLOW_LOCALHOST_CORS=true.
CORS_ORIGINS=https://your-admin-domain.com,https://your-customer-domain.com
ALLOW_LOCALHOST_CORS=true

# Used in welcome email links
CUSTOMER_APP_URL=https://your-customer-domain.com
CLIENT_URL=https://your-customer-domain.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@example.com
